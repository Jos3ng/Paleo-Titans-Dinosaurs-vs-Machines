      owned: {},
      team: [],
      upgrades: Object.fromEntries(upgrades.map(u => [u.id, 0])),
      relics: Object.fromEntries(relics.map(r => [r.id, 0])),
      equipment: [],
      achievements: {},
      missions: {},
      stats: { clicks: 0, hatches: 0, wins: 0, defeats: 0, bosses: 0, fossilsEarned: 0, prestiges: 0, maxRunStage: 1 },
      log: []
    });

    let state = load();
    let lastTick = performance.now();
    let animationTime = 0;
    let selectedTab = "collection";

    const $ = id => document.getElementById(id);
    const canvas = $("battleCanvas");
    const ctx = canvas.getContext("2d");

    function load() {
      try {
        const raw = localStorage.getItem(SAVE_KEY);
        if (!raw) return defaultState();
        const parsed = JSON.parse(raw);
        const base = defaultState();
        const merged = { ...base, ...parsed, stats: { ...base.stats, ...(parsed.stats || {}) } };
        merged.relics = { ...base.relics, ...(parsed.relics || {}) };
        merged.missions = { ...base.missions, ...(parsed.missions || {}) };
        merged.upgrades = { ...base.upgrades, ...(parsed.upgrades || {}) };
        merged.runArtifacts = parsed.runArtifacts || [];
        merged.equipment = parsed.equipment || [];
        return merged;
      } catch {
        return defaultState();
      }
    }

    function save() {
      localStorage.setItem(SAVE_KEY, JSON.stringify(state));
    }

    function fmt(value) {
      if (!Number.isFinite(value)) return "0";
      if (value < 1000) return Math.floor(value).toString();
      const units = ["K", "M", "B", "T", "Qa", "Qi"];
      let v = value;
      let unit = -1;
      while (v >= 1000 && unit < units.length - 1) {
        v /= 1000;
        unit++;
      }
      return v.toFixed(v >= 100 ? 0 : v >= 10 ? 1 : 2) + units[unit];
    }

    function rarityLabel(rarity) {
      return rarities.find(r => r.name === rarity)?.label || rarity;
    }

    function elementData(name) {
      return elements.find(e => e.name === name) || elements[8];
    }

    function pickTrait() {
      const total = traits.reduce((sum, trait) => sum + trait.chance, 0);
      let roll = Math.random() * total;
      for (const trait of traits) {
        roll -= trait.chance;
        if (roll <= 0) return trait.name;
      }
      return "Feroz";
    }

    function traitData(name) {
      return traits.find(t => t.name === name) || traits[0];
    }

    function traitScore(name) {
      const t = traitData(name);
      return t.attack * t.hp * t.xp * t.all;
    }

    function relicLevel(id) {
      return state.relics?.[id] || 0;
    }

    function artifactMult(key, fallback = 1) {
      return (state.runArtifacts || []).reduce((mult, id) => {
        const artifact = artifactCatalog.find(a => a.id === id);
        return mult * (artifact?.[key] || fallback);
      }, 1);
    }

    function collectionBonuses(s = state) {
      const ownedIds = Object.keys(s.owned || {});
      const adultCount = Object.values(s.owned || {}).filter(o => o.evo >= 2).length;
      const legendaryCount = ownedIds.filter(id => {
        const base = dinos.find(d => d.id === id);
        return base && (base.rarity === "Lendario" || base.rarity === "Mitico");
      }).length;
      const bonuses = [];

      for (const element of elements) {
        const total = dinos.filter(d => d.element === element.name).length;
        const owned = ownedIds.filter(id => dinos.find(d => d.id === id)?.element === element.name).length;
        if (owned >= 3) bonuses.push({ id: "e3_" + element.name, name: `3 ${element.name}`, desc: "+10% produção global", fossil: 1.1 });
        if (owned >= total) bonuses.push({ id: "efull_" + element.name, name: `${element.name} completo`, desc: "+20% HP global", hp: 1.2, complete: true });
      }

      if (adultCount >= 10) bonuses.push({ id: "adult10", name: "10 adultos", desc: "+15% ataque", attack: 1.15 });
      if (legendaryCount >= 5) bonuses.push({ id: "legendary", name: "Coleção lendária", desc: "+50% fósseis", fossil: 1.5 });
      return bonuses;
    }

    function synergyBonuses() {
      const team = state.team.map(ownedDino).filter(Boolean);
      const counts = {};
      for (const d of team) counts[d.element] = (counts[d.element] || 0) + 1;
      const unique = Object.keys(counts).length;
      const bonuses = { attack: 1, hp: 1, cooldown: 1, crit: 0, regen: 0, shield: 1, pierce: 0, names: [] };

      if (team.length === 5 && unique === 1) {
        bonuses.attack *= 1.3;
        bonuses.hp *= 1.3;
        bonuses.names.push(`Equipe monoelemental ${team[0].element}: +30% ATQ/HP`);
      }
      if (team.length === 5 && unique === 5) {
        bonuses.attack *= 1.2;
        bonuses.hp *= 1.2;
        bonuses.cooldown *= .85;
        bonuses.names.push("Equipe diversificada: +20% atributos e recarga menor");
      }
      if ((counts.Fogo || 0) >= 2 && (counts.Raio || 0) >= 2) {
        bonuses.crit += .4;
        bonuses.names.push("2 Fogo + 2 Raio: +40% dano crítico");
      }
      if ((counts.Água || 0) >= 2 && (counts.Terra || 0) >= 2) {
        bonuses.regen += .018;
        bonuses.names.push("2 Água + 2 Terra: regeneração constante");
      }
      if ((counts.Luz || 0) >= 2 && (counts.Trevas || 0) >= 2) {
        bonuses.pierce += .18;
        bonuses.names.push("2 Luz + 2 Trevas: ignora defesa");
      }
      if ((counts.Pedra || 0) >= 2 && (counts.Terra || 0) >= 2) {
        bonuses.shield *= 1.3;
        bonuses.names.push("2 Pedra + 2 Terra: escudos +30%");
      }
      return bonuses;
    }

    function globalBonuses() {
      const collection = collectionBonuses();
      const fossil = collection.reduce((m, b) => m * (b.fossil || 1), 1) * Math.pow(1.05, relicLevel("museum")) * artifactMult("fossil");
      const attack = collection.reduce((m, b) => m * (b.attack || 1), 1) * Math.pow(1.08, relicLevel("warRoom")) * artifactMult("attack");
      const hp = collection.reduce((m, b) => m * (b.hp || 1), 1) * Math.pow(1.08, relicLevel("titanNursery")) * artifactMult("hp");
      const xp = Math.pow(1.1, relicLevel("advancedLab"));
      const luck = Math.pow(1.1, relicLevel("geneBank"));
      return { fossil, attack, hp, xp, luck };
    }

    function ownedDino(id) {
      const base = dinos.find(d => d.id === id);
      const owned = state.owned[id];
      if (!base || !owned) return null;
      const evoMult = [1, 1.75, 2.8][owned.evo || 0];
      const levelMult = 1 + ((owned.level || 1) - 1) * 0.11;
      const trait = traitData(owned.trait || "Feroz");
      const spec = specializationCatalog.find(s => s.id === owned.specialization) || null;
      const equip = equipmentBonus(id);
      const globals = globalBonuses();
      const attack = Math.round(base.attack * evoMult * levelMult * trait.attack * trait.all * (spec?.attack || 1) * equip.attack * globals.attack);
      const hp = Math.round(base.hp * evoMult * levelMult * trait.hp * trait.all * (spec?.hp || 1) * equip.hp * globals.hp);
      return { ...base, ...owned, trait: owned.trait || "Feroz", hp, attack, evoName: stageNames[owned.evo || 0], specialization: owned.specialization, spec };
    }

    function equipmentBonus(id) {
      return (state.equipment || []).filter(e => e.owner === id).reduce((bonus, item) => {
        bonus.attack *= item.attack || 1;
        bonus.hp *= item.hp || 1;
        bonus.fossil *= item.fossil || 1;
        return bonus;
      }, { attack: 1, hp: 1, fossil: 1 });
    }

    function clickPower() {
      return (1 + upgrades.reduce((sum, u) => sum + (state.upgrades[u.id] || 0) * u.click, 0)) * globalBonuses().fossil;
    }

    function passiveFps() {
      const upgradeFps = upgrades.reduce((sum, u) => sum + (state.upgrades[u.id] || 0) * u.fps, 0);
      const dinoFps = state.team.map(ownedDino).filter(Boolean).reduce((sum, d) => sum + d.attack * 0.045, 0);
      return (upgradeFps + dinoFps) * globalBonuses().fossil;
    }

    function teamPower() {
      const synergy = synergyBonuses();
      return state.team.map(ownedDino).filter(Boolean).reduce((sum, d) => sum + d.attack * synergy.attack + d.hp * synergy.hp * 0.18, 0);
    }

    function eggCost() {
      const owned = Object.keys(state.owned).length;
      return Math.round(120 * Math.pow(1.095, state.stats.hatches) + owned * 16);
    }

    function upgradeCost(upgrade) {
      const level = state.upgrades[upgrade.id] || 0;
      return Math.round(upgrade.base * Math.pow(upgrade.scale, level));
    }

    function levelCost(dino) {
      const rarity = rarities.find(r => r.name === dino.rarity);
      return Math.round((95 + dino.level * 42) * rarity.mult * Math.pow(1.18, dino.level));
    }

    function evolutionCost(dino) {
      const rarity = rarities.find(r => r.name === dino.rarity);
      const target = dino.evo === 0 ? 1 : 2;
      return Math.round((target === 1 ? 850 : 4200) * rarity.mult * (1 + dino.level * .08));
    }

    function relicCost(relic) {
      const level = relicLevel(relic.id);
      return Math.round(relic.base + level * relic.dna + Math.pow(level, 2));
    }

    function addFossils(amount, reason) {
      const gained = Math.max(0, amount);
      state.fossils += gained;
      state.stats.fossilsEarned += gained;
      if (reason) log(`${reason}: +${fmt(gained)} fósseis.`);
    }

    function spendFossils(amount) {
      if (state.fossils < amount) return false;
      state.fossils -= amount;
      return true;
    }

    function log(message) {
      state.log.unshift({ message, time: Date.now() });
      state.log = state.log.slice(0, 18);
    }

    function toast(message) {
      const node = $("toast");
      node.textContent = message;
      node.classList.add("show");
      clearTimeout(toast.timer);
      toast.timer = setTimeout(() => node.classList.remove("show"), 2300);
    }

    function weightedRandomRarity() {
      const luck = globalBonuses().luck;
      const total = rarities.reduce((sum, r, index) => sum + r.weight * Math.pow(luck, index), 0);
      let roll = Math.random() * total;
      for (let i = 0; i < rarities.length; i++) {
        const rarity = rarities[i];
        roll -= rarity.weight * Math.pow(luck, i);
        if (roll <= 0) return rarity.name;
      }
      return "Comum";
    }

    function hatchEgg() {
      const cost = eggCost();
      if (!spendFossils(cost)) {
        toast("Fósseis insuficientes para incubar.");
        return;
      }

      const rarity = weightedRandomRarity();
      const pool = dinos.filter(d => d.rarity === rarity);
      const dino = pool[Math.floor(Math.random() * pool.length)] || dinos[Math.floor(Math.random() * dinos.length)];
      const rarityData = rarities.find(r => r.name === dino.rarity);
      state.stats.hatches++;

      if (!state.owned[dino.id]) {
        const trait = pickTrait();
        state.owned[dino.id] = { level: 1, xp: 0, evo: 0, currentHp: dino.hp, trait, cooldown: 0, shield: 0, owner: null };
        log(`Ovo chocado: ${dino.name} (${rarityLabel(dino.rarity)} de ${dino.element}, trait ${trait}).`);
        toast(`${dino.name} entrou na coleção.`);
        if (state.team.length < 5) state.team.push(dino.id);
      } else {
        const owned = state.owned[dino.id];
        const newTrait = pickTrait();
        if (traitScore(newTrait) > traitScore(owned.trait || "Feroz")) {
          owned.trait = newTrait;
          log(`Novo exemplar superior: ${dino.name} agora possui trait ${newTrait}.`);
        }
        owned.xp += rarityData.xp * globalBonuses().xp * traitData(owned.trait || "Feroz").xp;
        const needed = 3 + owned.level;
        if (owned.xp >= needed) {
          owned.xp -= needed;
          owned.level++;
          toast(`${dino.name} subiu para o nível ${owned.level}.`);
        } else {
          toast(`${dino.name} recebeu XP.`);
        }
        log(`Repetido: ${dino.name} ganhou ${rarityData.xp} XP.`);
      }

      checkEvolutions();
      checkAchievements();
      checkMissions();
      render();
      save();
    }

    function checkEvolutions() {
      for (const [id, owned] of Object.entries(state.owned)) {
        const base = dinos.find(d => d.id === id);
        const rarity = rarities.find(r => r.name === base.rarity);
        owned.trait = owned.trait || "Feroz";
        owned.cooldown = owned.cooldown || 0;
        owned.shield = owned.shield || 0;
        const max = Math.round(base.hp * [1, 1.75, 2.8][owned.evo] * (1 + (owned.level - 1) * 0.11));
        owned.currentHp = Math.min(max, owned.currentHp || max);
        owned.evoProgress = Math.min(100, Math.round((owned.level / (owned.evo === 0 ? 5 : owned.evo === 1 ? 10 : rarity.evo)) * 100));
      }
    }

    function levelUpDino(id) {
      const dino = ownedDino(id);
      if (!dino) return;
      const cost = levelCost(dino);
      if (!spendFossils(cost)) return toast("Fósseis insuficientes para treinar.");
      state.owned[id].level++;
      log(`${dino.name} treinou e chegou ao nível ${state.owned[id].level}.`);
      checkEvolutions();
      healTeam();
      checkAchievements();
      checkMissions();
      render();
      save();
    }

    function evolveDino(id) {
      const dino = ownedDino(id);
      if (!dino) return;
      if (dino.evo === 0 && dino.level < 5) return toast("Nível 5 necessário para evoluir.");
      if (dino.evo === 1 && dino.level < 10) return toast("Nível 10 necessário para evoluir.");
      if (dino.evo >= 2) return toast("Este dinossauro já está adulto.");
      const cost = evolutionCost(dino);
      if (!spendFossils(cost)) return toast("Fósseis insuficientes para evolução.");
      state.owned[id].evo++;
      if (state.owned[id].evo === 2 && !state.owned[id].specialization) state.owned[id].specialization = specializationCatalog[id.charCodeAt(id.length - 1) % specializationCatalog.length].id;
      log(`${dino.name} evoluiu para ${stageNames[state.owned[id].evo]}.`);
      healTeam();
      checkAchievements();
      checkMissions();
      render();
      save();
    }

    function chooseSpecialization(id, specId) {
      if (!state.owned[id] || state.owned[id].evo < 2) return;
      state.owned[id].specialization = specId;
      const dino = dinos.find(d => d.id === id);
      const spec = specializationCatalog.find(s => s.id === specId);
      log(`${dino.name} escolheu ${spec.name}.`);
      healTeam();
      render();
      save();
    }

    function buyUpgrade(id) {
      const upgrade = upgrades.find(u => u.id === id);
      const cost = upgradeCost(upgrade);
      if (!spendFossils(cost)) {
        toast("Fósseis insuficientes para esta melhoria.");
        return;
      }
      state.upgrades[id] = (state.upgrades[id] || 0) + 1;
      log(`${upgrade.name} aprimorada para nível ${state.upgrades[id]}.`);
      checkAchievements();
      render();
      save();
    }

    function buyRelic(id) {
      const relic = relics.find(r => r.id === id);
      const cost = relicCost(relic);
      if ((state.dna || 0) < cost) return toast("DNA ancestral insuficiente.");
      state.dna -= cost;
      state.relics[id] = relicLevel(id) + 1;
      log(`${relic.name} aprimorada para nível ${state.relics[id]}.`);
      render();
      save();
    }

    function prestige() {
      if (state.bestStage < 15) return toast("Prestígio libera ao alcançar fase 15.");
      const gained = Math.max(1, Math.floor(Math.sqrt(state.bestStage - 10) + state.stats.bosses * .25));
      state.dna = (state.dna || 0) + gained;
      state.stats.prestiges++;
      state.runStage = 1;
      state.inFight = false;
      state.robot = null;
      state.fightTime = FIGHT_SECONDS;
      state.runArtifacts = [];
      state.runEvent = null;
      healTeam();
      log(`Prestígio concluído: +${gained} DNA ancestral.`);
      render();
      save();
    }

    function equipDino(id) {
      if (!state.owned[id]) return;
      if (state.team.includes(id)) {
        state.team = state.team.filter(x => x !== id);
        toast("Removido da equipe.");
      } else {
        if (state.team.length >= 5) {
          toast("A equipe já tem 5 dinossauros.");
          return;
        }
        state.team.push(id);
        toast("Dinossauro equipado.");
      }
      healTeam();
      checkAchievements();
      render();
      save();
    }

    function healTeam() {
      for (const id of state.team) {
        const d = ownedDino(id);
        if (d) {
          state.owned[id].currentHp = d.hp;
          state.owned[id].shield = 0;
          state.owned[id].cooldown = 0;
        }
      }
    }

    function createRobot(stage) {
      const template = robotCatalog[(stage - 1) % robotCatalog.length];
      const element = elementData(template.element);
      const boss = stage % 10 === 0;
      const elite = stage % 5 === 0 && !boss;
      const loop = Math.floor((stage - 1) / robotCatalog.length);
      const typeHp = template.type === "Tanque" ? 1.45 : template.type === "Mecha" ? 1.22 : template.type === "Torre de defesa" ? 1.12 : template.type === "Drone" ? .78 : 1;
      const typeAtk = template.type === "Drone" ? 1.25 : template.type === "Androide" ? 1.18 : template.type === "Tanque" ? .85 : template.type === "Mecha" ? 1.25 : 1;
      const hp = Math.round((90 + stage * 38) * Math.pow(1.081, stage) * Math.pow(1.35, loop) * typeHp * (boss ? 3.4 : elite ? 1.65 : 1));
      const attack = Math.round((8 + stage * 3.75) * Math.pow(1.049, stage) * Math.pow(1.18, loop) * typeAtk * (boss ? 1.85 : elite ? 1.3 : 1));
      return {
        id: template.id,
        name: boss ? `${template.name} ${roman((stage % 12) + 1)}` : template.name,
        type: template.type,
        element: element.name,
        hp,
        maxHp: hp,
        attack,
        defense: Math.min(.45, stage * .006 + (template.type === "Tanque" ? .12 : 0) + (boss ? .08 : 0)),
        boss,
        phase: 1,
        special: boss ? `${template.special}: três fases` : elite ? `${template.special}: elite` : template.special,
        cooldown: template.type === "Drone" ? 1.85 : template.type === "Tanque" ? 3.1 : 2.55
      };
    }

    function roman(num) {
      const map = [["X",10],["IX",9],["V",5],["IV",4],["I",1]];
      let out = "";
      for (const [letter, value] of map) {
        while (num >= value) {
          out += letter;
          num -= value;
        }
      }
      return out;
    }

    function startRun() {
      state.runStage = 1;
      state.inFight = false;
      state.robot = null;
      state.runArtifacts = [];
      state.runEvent = null;
      state.fightTime = FIGHT_SECONDS;
      healTeam();
      log("Nova run iniciada. A progressão permanente foi preservada.");
      render();
      save();
    }

    function startFight() {
      if (state.team.filter(Boolean).length === 0) {
        toast("Equipe ao menos um dinossauro.");
        return;
      }
      healTeam();
      state.robot = createRobot(state.runStage);
      state.inFight = true;
      state.fightTime = FIGHT_SECONDS;
      log(`Fase ${state.runStage}: ${state.robot.name} apareceu.`);
      render();
      save();
    }

    function elementMultiplier(attacker, defender) {
      if (attacker === "Nulo" && defender !== "Nulo") return 1.15;
      if (defender === "Nulo" && attacker !== "Nulo") return 0.75;
      const e = elementData(attacker);
      if (e.strong.includes(defender)) return 1.5;
      if (e.weak.includes(defender)) return 0.75;
      return 1;
    }

    function eventBonus() {
      const event = state.runEvent;
      if (!event || event.until < Date.now()) {
        state.runEvent = null;
        return {};
      }
      return event;
    }

    function maybeRunEvent() {
      if (state.runEvent || Math.random() > .055) return;
      const events = [
        { id: "meteor", name: "Meteorito", fossil: 2, until: Date.now() + 60000, desc: "+100% fósseis por 60s" },
        { id: "solar", name: "Tempestade Solar", element: "Raio", elementAttack: 1.5, until: Date.now() + 45000, desc: "+50% dano de Raio" },
        { id: "invasion", name: "Invasão Mecânica", rewards: 1.45, enemyAttack: 1.25, until: Date.now() + 50000, desc: "Robôs mais fortes, recompensas maiores" },
        { id: "discovery", name: "Descoberta Arqueológica", freeEgg: true, until: Date.now() + 10000, desc: "Ovo grátis encontrado" }
      ];
      state.runEvent = events[Math.floor(Math.random() * events.length)];
      if (state.runEvent.freeEgg) addFossils(eggCost(), "Descoberta Arqueológica");
      log(`Evento: ${state.runEvent.name} (${state.runEvent.desc}).`);
    }

    function useAbility(dino, alive, synergy) {
      const owned = state.owned[dino.id];
      const ability = dino.ability;
      if (!ability || owned.cooldown > 0) return { damage: 0, control: 0, heal: 0, buff: 1 };
      owned.cooldown = ability.cooldown * (synergy.cooldown || 1) * (dino.className === "Suporte" ? .86 : 1);
      const evoBoost = [1, 1.25, 1.65][dino.evo || 0];
      const result = { damage: 0, control: 0, heal: 0, buff: 1 };
      const maxHp = alive.reduce((sum, ally) => sum + ally.hp, 0);

      if (ability.kind === "heal") {
        const heal = maxHp * .13 * evoBoost;
        for (const ally of alive) state.owned[ally.id].currentHp = Math.min(ally.hp, (state.owned[ally.id].currentHp || ally.hp) + heal / alive.length);
        result.heal = heal;
      } else if (ability.kind === "regen") {
        owned.regen = 6;
      } else if (ability.kind === "shield") {
        for (const ally of alive) state.owned[ally.id].shield = (state.owned[ally.id].shield || 0) + ally.hp * .18 * evoBoost * synergy.shield;
      } else if (ability.kind === "damage") {
        result.damage = dino.attack * 2.2 * evoBoost;
      } else if (ability.kind === "crit") {
        owned.crit = 4;
      } else if (ability.kind === "buff") {
        owned.teamBuff = 5;
        result.buff = 1.28;
      } else if (ability.kind === "leech") {
        owned.leech = 5;
      } else if (ability.kind === "revive") {
        const fallenId = state.team.find(id => {
          const ally = ownedDino(id);
          return ally && (state.owned[id].currentHp || 0) <= 0;
        });
        if (fallenId) {
          const ally = ownedDino(fallenId);
          state.owned[fallenId].currentHp = ally.hp * .35;
        }
      } else if (ability.kind === "freeze") {
        state.robot.cooldown += 2.6 * evoBoost;
        result.control = .18;
      } else if (ability.kind === "defDown") {
        state.robot.defense = Math.max(0, state.robot.defense - .08 * evoBoost);
      } else if (ability.kind === "haste") {
        for (const ally of alive) state.owned[ally.id].cooldown = Math.max(0, (state.owned[ally.id].cooldown || 0) - 2.2 * evoBoost);
      }
      return result;
    }

    function combatTick(dt) {
      if (!state.inFight || !state.robot) return;
      state.fightTime -= dt;
      const alive = state.team.map(ownedDino).filter(d => d && (state.owned[d.id].currentHp || d.hp) > 0);
      if (alive.length === 0) return defeat("Todos os dinossauros foram abatidos.");

      let teamDamage = 0;
      let healing = 0;
      let control = 0;
      let buffs = 1;
      const synergy = synergyBonuses();
      const event = eventBonus();
      const regenFromSynergy = synergy.regen * alive.reduce((sum, d) => sum + d.hp, 0);

      for (const d of alive) {
        const owned = state.owned[d.id];
        owned.cooldown = Math.max(0, (owned.cooldown || 0) - dt);
        owned.crit = Math.max(0, (owned.crit || 0) - dt);
        owned.regen = Math.max(0, (owned.regen || 0) - dt);
        owned.teamBuff = Math.max(0, (owned.teamBuff || 0) - dt);
        owned.leech = Math.max(0, (owned.leech || 0) - dt);
        const abilityResult = useAbility(d, alive, synergy);
        const roleBonus = d.role === "Dano" ? 1.16 : d.role === "Buffs" ? 1.06 : 1;
        const evoSkill = [1, 1.18, 1.42][d.evo || 0];
        const mult = elementMultiplier(d.element, state.robot.element);
        const crit = owned.crit > 0 ? 1.85 : (Math.random() < synergy.crit * dt ? 1.7 : 1);
        const elementEvent = event.element === d.element ? event.elementAttack || 1 : 1;
        const artifactElement = state.runArtifacts.includes("solarStorm") && d.element === "Raio" ? 1.5 : 1;
        const defense = Math.max(0, state.robot.defense - synergy.pierce);
        const damage = (d.attack * roleBonus * evoSkill * mult * synergy.attack * crit * elementEvent * artifactElement * dt + abilityResult.damage) * Math.max(.25, 1 - defense);
        teamDamage += damage;
        buffs *= abilityResult.buff;
        if (d.role === "Cura" || d.element === "Luz" || d.element === "Água") healing += d.attack * 0.15 * dt;
        if (d.role === "Controle" || d.element === "Trevas") control += 0.04 * dt;
        if (d.role === "Buffs") buffs += 0.015 * dt;
        if (owned.regen > 0) healing += d.hp * .035 * dt;
        if (owned.leech > 0) owned.currentHp = Math.min(d.hp, (owned.currentHp || d.hp) + damage * .16);
        if (owned.teamBuff > 0) buffs *= 1.1;
      }

      state.robot.hp -= teamDamage * buffs;
      if (healing > 0 || regenFromSynergy > 0) {
        for (const d of alive) {
          state.owned[d.id].currentHp = Math.min(d.hp, (state.owned[d.id].currentHp || d.hp) + healing / alive.length + regenFromSynergy * dt / alive.length);
        }
      }

      state.robot.cooldown -= dt * (1 + control);
      if (state.robot.cooldown <= 0) {
        const target = alive[Math.floor(Math.random() * alive.length)];
        const eventAttack = event.enemyAttack || 1;
        let damage = state.robot.attack * eventAttack * elementMultiplier(state.robot.element, target.element) * (state.robot.boss ? 1.25 : 1) / synergy.hp;
        const shield = state.owned[target.id].shield || 0;
        const absorbed = Math.min(shield, damage);
        state.owned[target.id].shield = shield - absorbed;
        damage -= absorbed;
        state.owned[target.id].currentHp = Math.max(0, (state.owned[target.id].currentHp || target.hp) - damage);
        state.robot.cooldown = state.robot.boss ? 1.85 : 2.55;
      }

      if (state.robot.boss && state.robot.phase < 3 && state.robot.hp < state.robot.maxHp * (1 - state.robot.phase / 3)) {
        state.robot.phase++;
        state.robot.attack *= 1.18;
        state.robot.defense = Math.min(.55, state.robot.defense + .06);
        log(`${state.robot.name} entrou na fase ${state.robot.phase}.`);
      }

      if (state.robot.hp <= 0) victory();
      else if (state.fightTime <= 0) defeat("O temporizador chegou a zero.");
    }

    function victory() {
      const robot = state.robot;
      state.inFight = false;
      const event = eventBonus();
      const rewardMult = artifactMult("rewards") * (event.rewards || 1);
      const reward = Math.round((55 + state.runStage * 32 + robot.maxHp * 0.16) * (robot.boss ? 3 : 1) * rewardMult);
      addFossils(reward, robot.boss ? "Chefe derrotado" : "Robô derrotado");
      state.stats.wins++;
      if (robot.boss) state.stats.bosses++;
      state.runStage++;
      state.bestStage = Math.max(state.bestStage, state.runStage);
      state.stats.maxRunStage = Math.max(state.stats.maxRunStage || 1, state.runStage);
      state.robot = null;
      state.fightTime = FIGHT_SECONDS;
      rewardTeamXp(robot.boss ? 2 : 1);
      maybeDropEquipment(robot);
      maybeDropArtifact(robot);
      maybeRunEvent();
      checkEvolutions();
      checkAchievements();
      checkMissions();
      render();
      save();
    }

    function maybeDropArtifact(robot) {
      if (state.runArtifacts.length >= 5) return;
      const chance = robot.boss ? .65 : .12;
      if (Math.random() > chance) return;
      const options = artifactCatalog.filter(a => !state.runArtifacts.includes(a.id));
      if (!options.length) return;
      const artifact = options[Math.floor(Math.random() * options.length)];
      state.runArtifacts.push(artifact.id);
      log(`Artefato de run encontrado: ${artifact.name} (${artifact.desc}).`);
    }

    function maybeDropEquipment(robot) {
      const chance = robot.boss ? .75 : .16;
      if (Math.random() > chance || !state.team.length) return;
      const rarity = weightedRandomRarity();
      const rarityData = rarities.find(r => r.name === rarity);
      const type = equipmentTypes[Math.floor(Math.random() * equipmentTypes.length)];
      const owner = state.team[Math.floor(Math.random() * state.team.length)];
      const item = {
        id: "eq" + Date.now() + Math.floor(Math.random() * 1000),
        owner,
        type,
        rarity,
        name: `${type} ${robot.element} ${rarityLabel(rarity)}`,
        attack: type === "Arma" || type === "Reator" ? 1 + rarityData.mult * .045 : 1,
        hp: type === "Armadura" || type === "Sensor" ? 1 + rarityData.mult * .05 : 1,
        fossil: type === "Sensor" ? 1.04 : 1
      };
      state.equipment.push(item);
      state.equipment = state.equipment.slice(-80);
      const dino = dinos.find(d => d.id === owner);
      log(`Peça obtida: ${item.name} equipada em ${dino?.name || "aliado"}.`);
    }

    function rewardTeamXp(amount) {
      for (const id of state.team) {
        if (state.owned[id]) {
          state.owned[id].xp += amount * globalBonuses().xp * traitData(state.owned[id].trait || "Feroz").xp;
          const need = 3 + state.owned[id].level;
          if (state.owned[id].xp >= need) {
            state.owned[id].xp -= need;
            state.owned[id].level++;
            const base = dinos.find(d => d.id === id);
            log(`${base.name} subiu para o nível ${state.owned[id].level} em combate.`);
          }
        }
      }
    }

    function defeat(reason) {
      state.inFight = false;
      state.stats.defeats++;
      const reached = state.runStage;
      const consolation = Math.max(15, Math.round(reached * 18 + teamPower() * 0.08));
      addFossils(consolation, "Retirada estratégica");
      log(`${reason} Run encerrada na fase ${reached}.`);
      state.runStage = 1;
      state.robot = null;
      state.runArtifacts = [];
      state.runEvent = null;
      state.fightTime = FIGHT_SECONDS;
      healTeam();
      checkAchievements();
      checkMissions();
      render();
      save();
    }

    function checkAchievements() {
      for (const achievement of achievements) {
        if (!state.achievements[achievement.id] && achievement.check(state)) {
          state.achievements[achievement.id] = true;
          addFossils(achievement.reward, `Conquista: ${achievement.name}`);
          toast(`Conquista: ${achievement.name}`);
        }
      }
    }

    function checkMissions() {
      for (const mission of missions) {
        if (!state.missions[mission.id] && mission.check(state)) {
          state.missions[mission.id] = true;
          addFossils(mission.reward, `Missão: ${mission.name}`);
          toast(`Missão concluída: ${mission.name}`);
        }
      }
    }

    function render() {
      $("fossils").textContent = fmt(state.fossils);
      $("dna").textContent = fmt(state.dna || 0);
      $("fps").textContent = fmt(passiveFps()) + "/s";
      $("run").textContent = "Fase " + state.runStage;
      $("best").textContent = "Fase " + state.bestStage;
      $("clickPower").textContent = fmt(clickPower());
      $("teamPower").textContent = fmt(teamPower());
      $("ownedCount").textContent = `${Object.keys(state.owned).length}/${dinos.length}`;
      $("eggCost").textContent = fmt(eggCost());
      $("hatchBtn").textContent = `Incubar ovo (${fmt(eggCost())} 🦴)`;
      $("hatchBtn").disabled = state.fossils < eggCost();
      $("battleStatus").textContent = battleStatusText();
      $("timer").textContent = state.inFight ? `${Math.max(0, state.fightTime).toFixed(1)}s` : "20.0s";

      const robot = state.robot || createRobot(state.runStage);
      $("robotLabel").textContent = robot.name + " • " + elementData(robot.element).icon + " " + robot.element;
      $("robotHp").style.width = `${Math.max(0, Math.min(100, (robot.hp / robot.maxHp) * 100))}%`;
      $("startRunBtn").disabled = state.inFight;
      $("nextFightBtn").disabled = state.inFight || state.team.length === 0;

      renderTeam();
      renderRunStats();
      renderLog();
      renderCollection();
      renderUpgrades();
      renderStrategy();
      renderRun();
      renderRelics();
      renderAchievements();
      drawBattle();
    }

    function battleStatusText() {
      if (state.inFight && state.robot) {
        return `${state.robot.special}: ${fmt(Math.max(0, state.robot.hp))}/${fmt(state.robot.maxHp)} HP.`;
      }
      if (state.team.length === 0) return "Incube ovos e equipe até cinco dinossauros para lutar.";
      return `Próximo alvo pronto. Vantagens elementais aumentam ou reduzem dano.`;
    }

    function renderTeam() {
      const strip = $("teamStrip");
      strip.innerHTML = "";
      for (let i = 0; i < 5; i++) {
        const id = state.team[i];
        const slot = document.createElement("div");
        slot.className = "slot" + (id ? "" : " empty");
        if (!id) {
          slot.textContent = "Vazio";
        } else {
          const d = ownedDino(id);
          const hpPct = Math.max(0, Math.min(100, ((state.owned[id].currentHp || d.hp) / d.hp) * 100));
          slot.style.setProperty("--element-color", elementData(d.element).color);
          slot.style.setProperty("--bulk", d.art.bulk);
          slot.style.setProperty("--mark", `"${d.art.mark}"`);
          slot.innerHTML = `
            <div class="mini-dino" style="--element-color:${elementData(d.element).color};--bulk:${d.art.bulk};--mark:'${d.art.mark}'"></div>
            <b>${d.name}</b>
            <span>${elementData(d.element).icon} ${d.className} Nv.${d.level}</span>
            <div class="bar"><div class="fill" style="width:${hpPct}%"></div></div>
          `;
        }
        strip.appendChild(slot);
      }
    }

    function renderLog() {
      $("log").innerHTML = state.log.map(item => `<div>${item.message}</div>`).join("") || "<div>O diário de campo está pronto.</div>";
    }

    function renderRunStats() {
      const synergy = synergyBonuses();
      const event = eventBonus();
      $("runStats").innerHTML = `
        <div class="stat"><b>${state.stats.wins}</b><span>robôs derrotados</span></div>
        <div class="stat"><b>${state.stats.bosses}</b><span>chefes vencidos</span></div>
        <div class="stat"><b>${synergy.names.length || 0}</b><span>sinergias ativas</span></div>
      `;
      const artifacts = (state.runArtifacts || []).map(id => artifactCatalog.find(a => a.id === id)).filter(Boolean);
      const eventChip = event.name ? `<span class="artifact">${event.name}: ${event.desc}</span>` : "";
      $("artifactStrip").innerHTML = eventChip + artifacts.map(a => `<span class="artifact">${a.icon} ${a.name}</span>`).join("");
    }

    function renderCollection() {
      if (selectedTab !== "collection") return;
      const elementFilter = $("elementFilter").value || "Todos";
      const rarityFilter = $("rarityFilter").value || "Todos";
      const list = $("collectionList");
      const sorted = [...dinos].sort((a, b) => {
        const ao = state.owned[a.id] ? 0 : 1;
        const bo = state.owned[b.id] ? 0 : 1;
        return ao - bo || a.name.localeCompare(b.name);
      }).filter(d => (elementFilter === "Todos" || d.element === elementFilter) && (rarityFilter === "Todos" || d.rarity === rarityFilter));

      list.innerHTML = sorted.map(d => {
        const owned = ownedDino(d.id);
        const e = elementData(d.element);
        const inTeam = state.team.includes(d.id);
        const title = owned ? d.name : "Espécie não descoberta";
        const stats = owned ? `ATQ ${fmt(owned.attack)} • HP ${fmt(owned.hp)} • Nv.${owned.level}` : `${rarityLabel(d.rarity)} • ${d.element}`;
        const canEvolve = owned && ((owned.evo === 0 && owned.level >= 5) || (owned.evo === 1 && owned.level >= 10));
        const levelBtn = owned ? `<button onclick="levelUpDino('${d.id}')" ${state.fossils < levelCost(owned) ? "disabled" : ""}>Upar ${fmt(levelCost(owned))}</button>` : "";
        const evoBtn = owned && owned.evo < 2 ? `<button class="${canEvolve ? "primary" : ""}" onclick="evolveDino('${d.id}')" ${!canEvolve || state.fossils < evolutionCost(owned) ? "disabled" : ""}>Evoluir ${fmt(evolutionCost(owned))}</button>` : "";
        const equipBtn = owned ? `<button class="${inTeam ? "warn" : "primary"}" title="${inTeam ? "Remover da equipe" : "Equipar"}" onclick="equipDino('${d.id}')">${inTeam ? "Remover" : "Equipar"}</button>` : `<button disabled>Bloqueado</button>`;
        const specButtons = owned && owned.evo >= 2 ? specializationCatalog.map(s => `<button class="${owned.specialization === s.id ? "primary" : ""}" onclick="chooseSpecialization('${d.id}', '${s.id}')" title="${s.desc}">${s.name.split(" ")[0]}</button>`).join("") : "";
        const equipment = owned ? state.equipment.filter(item => item.owner === d.id).slice(-2).map(item => item.name).join(" • ") : "";
        return `
          <div class="dino-card ${owned ? "" : "locked"}" style="--element-color:${e.color}">
            <div class="${owned ? "mini-dino" : "badge-avatar"}" style="--element-color:${e.color};--bulk:${d.art.bulk};--mark:'${d.art.mark}'">${owned ? "" : "?"}</div>
            <div class="card-main">
              <b>${title}</b>
              <div class="small">${owned ? d.skill + " • " + d.lore : "Incube ovos para catalogar esta espécie."}</div>
              <div class="meta">
                <span class="chip">${e.icon} ${d.element}</span>
                <span class="chip">${d.className}</span>
                <span class="chip rarity-${d.rarity}">${rarityLabel(d.rarity)}</span>
                <span class="chip">${owned ? owned.evoName : "???"}</span>
                <span class="chip">${owned ? "Trait " + owned.trait : "Trait ???"}</span>
                <span class="chip">${stats}</span>
              </div>
              ${owned ? `<div class="progress-line" style="--pct:${Math.min(100, (owned.xp / (3 + owned.level)) * 100)}%"><i></i></div>` : ""}
              ${owned ? `<div class="ability-row">${specButtons}<span class="chip">${owned.spec?.name || "Sem especialização"}</span>${equipment ? `<span class="chip">${equipment}</span>` : ""}</div>` : ""}
            </div>
            <div class="card-actions wide">${equipBtn}${levelBtn}${evoBtn}</div>
          </div>`;
      }).join("");
    }

    function renderUpgrades() {
      if (selectedTab !== "upgrades") return;
      $("upgradeList").innerHTML = upgrades.map(u => {
        const level = state.upgrades[u.id] || 0;
        const cost = upgradeCost(u);
        return `
          <div class="upgrade-card">
            <div class="badge-avatar">${u.icon}</div>
            <div class="card-main">
              <b>${u.name}</b>
              <div class="small">Nível ${level} • +${fmt(u.click)} por clique • +${fmt(u.fps)}/s</div>
            </div>
            <button class="primary" onclick="buyUpgrade('${u.id}')" ${state.fossils < cost ? "disabled" : ""}>${fmt(cost)} 🦴</button>
          </div>`;
      }).join("");
    }

    function renderStrategy() {
      if (selectedTab !== "strategy") return;
      const rows = elements.map(e => {
        const weakText = e.weak.length ? e.weak.join(" e ") : "ninguém diretamente";
        return `
          <div class="upgrade-card" style="--element-color:${e.color}">
            <div class="badge-avatar">${e.icon}</div>
            <div class="card-main">
              <b>${e.name}</b>
              <div class="small">Forte contra ${e.strong.join(" e ")}. Fraco contra ${weakText}.</div>
            </div>
            <span class="chip">x1.50 / x0.75</span>
          </div>`;
      }).join("");
      const synergy = synergyBonuses();
      const teamRoles = state.team.map(ownedDino).filter(Boolean).map(d => `${d.name}: ${d.className} • ${d.role} • ${d.skill}`).join("<br>");
      const bonusRows = collectionBonuses().map(b => `
        <div class="achievement-card">
          <div class="badge-avatar">▣</div>
          <div class="card-main"><b>${b.name}</b><div class="small">${b.desc}</div></div>
          <span class="chip">Ativo</span>
        </div>
      `).join("");
      $("strategyList").innerHTML = `
        <div class="achievement-card">
          <div class="badge-avatar">⚔️</div>
          <div class="card-main">
            <b>Composição atual</b>
            <div class="small">${teamRoles || "Equipe vazia."}<br>${synergy.names.join("<br>") || "Sem sinergia especial ativa."}</div>
          </div>
          <span class="chip">${fmt(teamPower())} poder</span>
        </div>
        ${bonusRows}
        ${rows}
      `;
    }

    function renderRun() {
      if (selectedTab !== "run") return;
      const robotRows = robotCatalog.slice(0, 100).map((r, i) => `
        <div class="upgrade-card" style="--element-color:${elementData(r.element).color}">
          <div class="badge-avatar">${elementData(r.element).icon}</div>
          <div class="card-main">
            <b>${String(i + 1).padStart(3, "0")} • ${r.name}</b>
            <div class="small">${r.type} • ${r.element} • ${r.special}</div>
          </div>
          <span class="chip">${(i + 1) % 10 === 0 ? "Chefe" : "Robô"}</span>
        </div>
      `).join("");
      const artifactRows = artifactCatalog.map(a => `
        <div class="achievement-card">
          <div class="badge-avatar">${a.icon}</div>
          <div class="card-main"><b>${a.name}</b><div class="small">${a.desc}</div></div>
          <span class="chip">${state.runArtifacts.includes(a.id) ? "Ativo" : "Drop"}</span>
        </div>
      `).join("");
      const event = eventBonus();
      $("runList").innerHTML = `
        <div class="achievement-card">
          <div class="badge-avatar">∞</div>
          <div class="card-main">
            <b>Progressão roguelike</b>
            <div class="small">Fase atual ${state.runStage}. Recorde ${state.bestStage}. Ao perder, fósseis, dinossauros, evoluções, melhorias e relíquias permanecem.</div>
          </div>
          <span class="chip">${event.name || "Sem evento"}</span>
        </div>
        ${artifactRows}
        ${robotRows}
      `;
    }

    function renderRelics() {
      if (selectedTab !== "relics") return;
      $("relicList").innerHTML = relics.map(r => {
        const level = relicLevel(r.id);
        const cost = relicCost(r);
        return `
          <div class="upgrade-card">
            <div class="badge-avatar">${r.icon}</div>
            <div class="card-main">
              <b>${r.name}</b>
              <div class="small">${r.desc} • Nível ${level}</div>
            </div>
            <button class="primary" onclick="buyRelic('${r.id}')" ${(state.dna || 0) < cost ? "disabled" : ""}>${fmt(cost)} DNA</button>
          </div>`;
      }).join("");
    }

    function renderAchievements() {
      if (selectedTab !== "achievements") return;
      const missionRows = missions.map(m => {
        const done = !!state.missions[m.id];
        return `
          <div class="achievement-card">
            <div class="badge-avatar">${done ? "✓" : "!"}</div>
            <div class="card-main">
              <b>${m.name}</b>
              <div class="small">Recompensa permanente ao completar o objetivo.</div>
            </div>
            <span class="chip">${done ? "Concluída" : "+" + fmt(m.reward) + " 🦴"}</span>
          </div>`;
      }).join("");
      const achievementRows = achievements.map(a => {
        const done = !!state.achievements[a.id];
        return `
          <div class="achievement-card">
            <div class="badge-avatar">${done ? "🏆" : "◇"}</div>
            <div class="card-main">
              <b>${a.name}</b>
              <div class="small">${a.desc}</div>
            </div>
            <span class="chip">${done ? "Concluída" : "+" + fmt(a.reward) + " 🦴"}</span>
          </div>`;
      }).join("");
      $("achievementList").innerHTML = missionRows + achievementRows;
      $("prestigeBtn").disabled = state.bestStage < 15;
      $("prestigeBtn").textContent = state.bestStage < 15 ? "Prestígio fase 15" : `Prestígio (+${fmt(Math.max(1, Math.floor(Math.sqrt(state.bestStage - 10) + state.stats.bosses * .25)))} DNA)`;
    }

    function drawBattle() {
      const w = canvas.width;
      const h = canvas.height;
      animationTime += 0.016;
      ctx.clearRect(0, 0, w, h);
      const grd = ctx.createLinearGradient(0, 0, 0, h);
      grd.addColorStop(0, "#16212b");
      grd.addColorStop(.62, "#20242a");
      grd.addColorStop(1, "#332d25");
      ctx.fillStyle = grd;
      ctx.fillRect(0, 0, w, h);

      ctx.fillStyle = "rgba(240,216,156,.14)";
      for (let i = 0; i < 8; i++) {
        const x = (i * 151 + animationTime * 12) % (w + 120) - 60;
        ctx.beginPath();
        ctx.ellipse(x, h * .82 + Math.sin(animationTime + i) * 8, 65, 11, 0, 0, Math.PI * 2);
        ctx.fill();
      }

      ctx.fillStyle = "rgba(0,0,0,.24)";
      ctx.fillRect(0, h * .72, w, h * .28);
      ctx.strokeStyle = "rgba(255,255,255,.06)";
      ctx.lineWidth = 2;
      for (let x = 0; x < w; x += 80) {
        ctx.beginPath();
        ctx.moveTo(x, h * .72);
        ctx.lineTo(x - 60, h);
        ctx.stroke();
      }

      const team = state.team.map(ownedDino).filter(Boolean);
      team.forEach((d, i) => drawDino(115 + i * 92, 330 + Math.sin(animationTime * 2 + i) * 5, d, i));
      drawRobot(760, 300 + Math.sin(animationTime * 2.5) * 5, state.robot || createRobot(state.runStage));
    }

    function drawDino(x, y, d, index) {
      const e = elementData(d.element);
      const scale = [0.72, 0.9, 1.08][d.evo || 0];
      const art = d.art || {};
      const bulk = art.bulk || 0;
      ctx.save();
      ctx.translate(x, y);
      ctx.scale(scale, scale);
      ctx.fillStyle = e.color;
      ctx.strokeStyle = "rgba(255,255,255,.38)";
      ctx.lineWidth = 3;

      if (art.wings) {
        ctx.fillStyle = mixColor(e.color, "#ffffff", .2);
        ctx.beginPath();
        ctx.moveTo(-8, -14);
        ctx.quadraticCurveTo(-58, -72, -92, -15);
        ctx.quadraticCurveTo(-52, -28, -12, 4);
        ctx.moveTo(15, -15);
        ctx.quadraticCurveTo(72, -66, 92, -8);
        ctx.quadraticCurveTo(54, -22, 20, 6);
        ctx.fill();
        ctx.stroke();
      }

      if (art.fin) {
        ctx.fillStyle = mixColor(e.color, "#111318", .18);
        ctx.beginPath();
        ctx.ellipse(4, 0, 58 + bulk, 19, -0.03, 0, Math.PI * 2);
        ctx.fill();
        ctx.stroke();
        ctx.beginPath();
        ctx.moveTo(-42, -2);
        ctx.quadraticCurveTo(-90, -28, -104, -6);
        ctx.quadraticCurveTo(-82, 13, -42, 12);
        ctx.fill();
        ctx.stroke();
      } else {
        ctx.beginPath();
        ctx.ellipse(0, 0, 46 + bulk, 25 + bulk * .22, -0.08, 0, Math.PI * 2);
        ctx.fill();
        ctx.stroke();
      }

      if (art.sail) {
        ctx.fillStyle = mixColor(e.color, "#f7ef9d", .25);
        ctx.beginPath();
        ctx.moveTo(-30, -18);
        ctx.quadraticCurveTo(-8, -70, 24, -18);
        ctx.closePath();
        ctx.fill();
        ctx.stroke();
      }

      if (art.plates) {
        ctx.fillStyle = mixColor(e.color, "#eadab0", .3);
        for (let i = 0; i < 5; i++) {
          ctx.beginPath();
          ctx.moveTo(-36 + i * 18, -18);
          ctx.lineTo(-27 + i * 18, -42 - (i % 2) * 7);
          ctx.lineTo(-17 + i * 18, -17);
          ctx.closePath();
          ctx.fill();
          ctx.stroke();
        }
      }

      if (art.armor) {
        ctx.fillStyle = "rgba(255,255,255,.22)";
        for (let i = 0; i < 5; i++) {
          ctx.beginPath();
          ctx.arc(-28 + i * 15, -5 + (i % 2) * 9, 5, 0, Math.PI * 2);
          ctx.fill();
        }
      }

      if (art.neck) {
        ctx.strokeStyle = e.color;
        ctx.lineWidth = 18;
        ctx.beginPath();
        ctx.moveTo(32, -12);
        ctx.quadraticCurveTo(66, -72, 86, -42);
        ctx.stroke();
        ctx.strokeStyle = "rgba(255,255,255,.38)";
        ctx.lineWidth = 3;
        ctx.beginPath();
        ctx.ellipse(95, -44, 21, 15, .2, 0, Math.PI * 2);
        ctx.fill();
        ctx.stroke();
      } else {
        ctx.beginPath();
        ctx.ellipse(45, -22, art.horns ? 28 : 24, 18, .2, 0, Math.PI * 2);
        ctx.fill();
        ctx.stroke();
      }

      if (art.horns) {
        ctx.fillStyle = "#eadab0";
        [[56, -37], [38, -36], [66, -19]].forEach(([hx, hy], i) => {
          ctx.beginPath();
          ctx.moveTo(hx, hy);
          ctx.lineTo(hx + (i === 1 ? -18 : 18), hy - 14);
          ctx.lineTo(hx + (i === 1 ? -4 : 4), hy + 5);
          ctx.closePath();
          ctx.fill();
          ctx.stroke();
        });
      }

      ctx.fillStyle = e.color;
      ctx.beginPath();
      ctx.moveTo(-38, -4);
      ctx.quadraticCurveTo(-80 - bulk, -36, -96 - bulk, -12);
      ctx.quadraticCurveTo(-74, -5, -43, 10);
      ctx.fill();
      ctx.stroke();

      if (art.tailClub) {
        ctx.fillStyle = mixColor(e.color, "#111318", .22);
        ctx.beginPath();
        ctx.ellipse(-104 - bulk, -13, 14, 11, 0, 0, Math.PI * 2);
        ctx.fill();
        ctx.stroke();
      }

      ctx.strokeStyle = "rgba(0,0,0,.24)";
      ctx.lineWidth = 2;
      for (let i = 0; i <= art.stripes; i++) {
        ctx.beginPath();
        ctx.moveTo(-18 + i * 18, -19);
        ctx.lineTo(-28 + i * 18, 14);
        ctx.stroke();
      }

      ctx.fillStyle = "#111318";
      ctx.beginPath();
      ctx.arc(art.neck ? 101 : 53, art.neck ? -48 : -26, 3.8, 0, Math.PI * 2);
      ctx.fill();
      ctx.strokeStyle = "rgba(0,0,0,.38)";
      ctx.lineWidth = 5;
      ctx.beginPath();
      ctx.moveTo(-18 - bulk * .15, 18);
      ctx.lineTo(-26 - bulk * .1, 48);
      ctx.moveTo(22 + bulk * .12, 17);
      ctx.lineTo(14 + bulk * .1, 48);
      ctx.stroke();
      if (d.role === "Cura") {
        ctx.strokeStyle = "rgba(247,239,157,.55)";
        ctx.beginPath();
        ctx.arc(0, -6, 56 + Math.sin(animationTime * 5 + index) * 4, 0, Math.PI * 2);
        ctx.stroke();
      }
      ctx.restore();
    }

    function mixColor(hex, other, amount) {
      const parse = value => {
        const clean = value.replace("#", "");
        return [parseInt(clean.slice(0, 2), 16), parseInt(clean.slice(2, 4), 16), parseInt(clean.slice(4, 6), 16)];
      };
      const a = parse(hex);
      const b = parse(other);
      const c = a.map((v, i) => Math.round(v + (b[i] - v) * amount));
      return `rgb(${c[0]}, ${c[1]}, ${c[2]})`;
    }

    function drawRobot(x, y, robot) {
      const e = elementData(robot.element);
      ctx.save();
      ctx.translate(x, y);
      const pulse = state.inFight ? Math.sin(animationTime * 7) * 3 : 0;
      const type = robot.type || "Drone";
      const sx = type === "Tanque" ? 1.25 : type === "Drone" ? .78 : type === "Torre de defesa" ? .92 : type === "Chefe robótico" ? 1.35 : 1;
      const sy = type === "Mecha" || type === "Chefe robótico" ? 1.2 : type === "Drone" ? .82 : 1;
      ctx.scale(sx, sy);
      ctx.fillStyle = type === "Tanque" ? "#4c535b" : type === "Torre de defesa" ? "#303842" : "#3a414a";
      ctx.strokeStyle = e.color;
      ctx.lineWidth = 4;
      if (type === "Drone") {
        ctx.beginPath();
        ctx.ellipse(0, -42 - pulse, 60, 34, 0, 0, Math.PI * 2);
        ctx.fill();
        ctx.stroke();
        ctx.beginPath();
        ctx.arc(-70, -42 - pulse, 16, 0, Math.PI * 2);
        ctx.arc(70, -42 - pulse, 16, 0, Math.PI * 2);
        ctx.stroke();
      } else if (type === "Torre de defesa") {
        ctx.fillRect(-30, -116 - pulse, 60, 68);
        ctx.strokeRect(-30, -116 - pulse, 60, 68);
        ctx.fillRect(-58, -48 - pulse, 116, 48);
        ctx.strokeRect(-58, -48 - pulse, 116, 48);
        ctx.fillRect(-18, 0, 36, 78);
        ctx.strokeRect(-18, 0, 36, 78);
      } else {
        ctx.fillRect(-48, -70 - pulse, 96, 92);
        ctx.strokeRect(-48, -70 - pulse, 96, 92);
      }
      ctx.fillStyle = "#252b33";
      if (type !== "Drone" && type !== "Torre de defesa") {
        ctx.fillRect(-34, -104 - pulse, 68, 38);
        ctx.strokeRect(-34, -104 - pulse, 68, 38);
      }
      ctx.fillStyle = e.color;
      ctx.fillRect(type === "Drone" ? -24 : -22, type === "Drone" ? -48 - pulse : -91 - pulse, 14, 8);
      ctx.fillRect(type === "Drone" ? 10 : 8, type === "Drone" ? -48 - pulse : -91 - pulse, 14, 8);
      ctx.strokeStyle = "#767f88";
      ctx.lineWidth = 9;
      ctx.beginPath();
      if (type === "Tanque") {
        ctx.moveTo(-64, 28);
        ctx.lineTo(-88, 62);
        ctx.moveTo(64, 28);
        ctx.lineTo(88, 62);
      } else if (type !== "Torre de defesa") {
        ctx.moveTo(-48, -32 - pulse);
        ctx.lineTo(-92, 12);
        ctx.moveTo(48, -32 - pulse);
        ctx.lineTo(92, 12);
        ctx.moveTo(-24, 22);
        ctx.lineTo(-38, 74);
        ctx.moveTo(24, 22);
        ctx.lineTo(38, 74);
      }
      ctx.stroke();
      if (type === "Mecha" || robot.boss) {
        ctx.strokeStyle = e.color;
        ctx.lineWidth = 6;
        ctx.beginPath();
        ctx.moveTo(42, -58 - pulse);
        ctx.lineTo(92, -90 - pulse);
        ctx.lineTo(112, -86 - pulse);
        ctx.stroke();
      }
      if (robot.boss) {
        ctx.strokeStyle = "rgba(224,82,82,.55)";
        ctx.lineWidth = 3;
        ctx.beginPath();
        ctx.arc(0, -36, 84 + Math.sin(animationTime * 4) * 6, 0, Math.PI * 2);
        ctx.stroke();
      }
      ctx.restore();
    }

    function setupFilters() {
      $("elementFilter").innerHTML = `<option>Todos</option>` + elements.map(e => `<option>${e.name}</option>`).join("");
      $("rarityFilter").innerHTML = `<option>Todos</option>` + rarities.map(r => `<option value="${r.name}">${rarityLabel(r.name)}</option>`).join("");
    }

    function setupEvents() {
      $("rock").addEventListener("click", event => {
        const amount = clickPower();
        addFossils(amount);
        state.stats.clicks++;
        const wrap = $("rockWrap");
        const pop = document.createElement("div");
        pop.className = "gain-pop";
        pop.textContent = `+${fmt(amount)} 🦴`;
        const rect = wrap.getBoundingClientRect();
        pop.style.left = `${event.clientX - rect.left - 18}px`;
        pop.style.top = `${event.clientY - rect.top - 12}px`;
        wrap.appendChild(pop);
        setTimeout(() => pop.remove(), 800);
        $("rock").style.setProperty("--spark", "1");
        $("rock").style.setProperty("--spark-x", `${((event.clientX - rect.left) / rect.width) * 100}%`);
        $("rock").style.setProperty("--spark-y", `${((event.clientY - rect.top) / rect.height) * 100}%`);
        setTimeout(() => $("rock").style.setProperty("--spark", "0"), 150);
        checkAchievements();
        render();
      });

      $("hatchBtn").addEventListener("click", hatchEgg);
      $("saveBtn").addEventListener("click", () => { save(); toast("Jogo salvo."); });
      $("startRunBtn").addEventListener("click", startRun);
      $("nextFightBtn").addEventListener("click", startFight);
      $("prestigeBtn").addEventListener("click", prestige);
      $("elementFilter").addEventListener("change", renderCollection);
      $("rarityFilter").addEventListener("change", renderCollection);

      document.querySelectorAll(".tab").forEach(button => {
        button.addEventListener("click", () => {
          selectedTab = button.dataset.tab;
          document.querySelectorAll(".tab").forEach(b => b.classList.toggle("active", b === button));
          document.querySelectorAll(".view").forEach(v => v.classList.toggle("active", v.id === selectedTab));
          render();
        });
      });

      $("exportBtn").addEventListener("click", async () => {
        const data = btoa(unescape(encodeURIComponent(JSON.stringify(state))));
        try {
          await navigator.clipboard.writeText(data);
          toast("Save exportado para a área de transferência.");
        } catch {
          prompt("Copie seu save:", data);
        }
      });

      $("resetBtn").addEventListener("click", () => {
        if (!confirm("Resetar todo o progresso permanente?")) return;
        localStorage.removeItem(SAVE_KEY);
        state = defaultState();
        log("Progresso reiniciado.");
        render();
        save();
      });

      window.addEventListener("beforeunload", save);
    }

    function loop(now) {
      const dt = Math.min(1, (now - lastTick) / 1000);
      lastTick = now;
      if (dt > 0) {
        addFossils(passiveFps() * dt);
        combatTick(dt);
      }
      renderLight();
      drawBattle();
      requestAnimationFrame(loop);
    }

    function renderLight() {
      $("fossils").textContent = fmt(state.fossils);
      $("dna").textContent = fmt(state.dna || 0);
      $("fps").textContent = fmt(passiveFps()) + "/s";
      $("timer").textContent = state.inFight ? `${Math.max(0, state.fightTime).toFixed(1)}s` : "20.0s";
      if (state.robot) {
        $("robotHp").style.width = `${Math.max(0, Math.min(100, (state.robot.hp / state.robot.maxHp) * 100))}%`;
        $("battleStatus").textContent = battleStatusText();
      }
      $("hatchBtn").disabled = state.fossils < eggCost();
      renderRunStats();
    }

    setupFilters();
    setupEvents();
    checkEvolutions();
    checkAchievements();
    checkMissions();
    render();
    setInterval(save, 10000);
    setInterval(() => {
      render();
      save();
    }, 1600);
    requestAnimationFrame(loop);

    window.equipDino = equipDino;
    window.buyUpgrade = buyUpgrade;
    window.buyRelic = buyRelic;
    window.levelUpDino = levelUpDino;
    window.evolveDino = evolveDino;
    window.chooseSpecialization = chooseSpecialization;
  </script>
</body>
</html>
